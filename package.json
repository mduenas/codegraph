{
  "name": "@mduenas/codegraph",
  "version": "0.6.5",
  "description": "Supercharge Claude Code with semantic code intelligence. 30% fewer tokens, 25% fewer tool calls, 100% local.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codegraph": "./dist/bin/codegraph.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "postinstall": "node scripts/postinstall.js",
    "copy-assets": "mkdir -p dist/db && cp src/db/schema.sql dist/db/ && (cp -r src/extraction/queries dist/extraction/ 2>/dev/null || true)",
    "dev": "tsc --watch",
    "cli": "npm run build && node dist/bin/codegraph.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run __tests__/evaluation/",
    "eval": "npm run build && npx tsx __tests__/evaluation/runner.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis",
    "semantic-search"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.19.30",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0"
  }
}
